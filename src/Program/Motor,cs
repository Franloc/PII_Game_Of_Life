class MotorDeReglas
{
    public void Generacion(Board boardObj) 
    {
        bool[,] gameBoard = boardObj.getBoard(); //tablero actual y sus dimensiones 
        int boardWidth = gameBoard.GetLength(0);
        int boardHeight = gameBoard.GetLength(1);

        bool[,] cloneboard = new bool[boardWidth, boardHeight]; //nuevo tablero donde se guarda la siguiente generacion de celulas

        for (int x = 0; x < boardWidth; x++) //recorre el tablero
        {   
            for (int y = 0; y < boardHeight; y++)
            {
                int aliveNeighbors = 0; //cuantos vecinos vivos tiene la celula
                for (int i = x-1; i<=x+1;i++) //revisa posiciones alrededor de la celula
                {
                    for (int j = y-1;j<=y+1;j++)
                    {  
                        if(i>=0 && i<boardWidth && j>=0 && j < boardHeight && gameBoard[i,j])
                        {
                            aliveNeighbors++;
                        }
                    }
                }
        
                if(gameBoard[x,y])
                {
                    aliveNeighbors--;
                } 
                    //Las reglas sobre el juego
                if (gameBoard[x,y] && aliveNeighbors < 2) 
                {
                    //Celula muere por baja población
                    cloneboard[x,y] = false;
                }
                else if (gameBoard[x,y] && aliveNeighbors > 3)
                {
                    //Celula muere por sobrepoblación
                    cloneboard[x,y] = false;
                }
                else if (!gameBoard[x,y] && aliveNeighbors == 3)
                {
                    //Celula nace por reproducción
                    cloneboard[x,y] = true;
                }
                else
                {
                    //Celula mantiene el estado que tenía
                    cloneboard[x,y] = gameBoard[x,y];
                }
            }
        }
    }
} 